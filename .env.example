POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# 0 = EOA, 1 = POLY_PROXY, 2 = GNOSIS_SAFE, 3 = POLY_1271
# Polymarket.com 网页账户通常用 2，并且要配 POLYMARKET_FUNDER_ADDRESS=你的 proxy wallet
POLYMARKET_SIGNATURE_TYPE=0

# Required: your signer private key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Required for type 1/2/3. For type 0, defaults to signer address.
POLYMARKET_FUNDER_ADDRESS=0xYOUR_FUNDER_ADDRESS

# Optional. If omitted, the script derives or re-derives them automatically.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=
